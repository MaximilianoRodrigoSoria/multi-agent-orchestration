# === Proveedor de LLM de los agentes ===
# "ollama" (local, sin costo) o "anthropic" (Claude, por API).
LLM_PROVIDER=ollama

# === Claude / Anthropic ===
# Obtené tu API key en https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_MODEL=claude-sonnet-5
LLM_MAX_TOKENS=1024

# === Ollama (local) — usar con LLM_PROVIDER=ollama ===
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# === Gate human-in-the-loop ===
# true = aprueba automáticamente (demo no interactiva); false = pregunta por CLI.
AUTO_APPROVE=false
